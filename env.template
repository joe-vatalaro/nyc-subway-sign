# MTA API Key - Only required if using bus routes
# Get yours from https://api.mta.info/
# Subway routes work without an API key
MTA_API_KEY=your_api_key_here

# Update interval in seconds (how often to fetch new data)
UPDATE_INTERVAL=30

# Verbose terminal output (true/false) - Print detailed arrival info to terminal
VERBOSE_TERMINAL=true

