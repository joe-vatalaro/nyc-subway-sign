# BusTime API Key (MTA Bus Time) - required for bus arrivals
BUSTIME_API_KEY=your_bustime_api_key_here

# Bus API mode: "siri" (recommended) or "gtfsrt"
BUS_API_MODE=siri

# Update interval in seconds (how often to fetch new data)
UPDATE_INTERVAL=30

# Verbose terminal output (true/false) - Print detailed arrival info to terminal
VERBOSE_TERMINAL=true

# Terminal colors (true/false) - ANSI colors in terminal output
TERMINAL_COLORS=true

